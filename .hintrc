{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "border-color: color-mix(in srgb, #000 8%, transparent)",
          "background-color: color-mix(in srgb, #000 4%, transparent)",
          "background-color: color-mix(in srgb, #000 4%, transparent)",
          "border-color: color-mix(in srgb, #fff 14.499999999999998%, transparent)"
        ]
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not chrome <= 109",
    "not ios_saf <= 15.8"
  ]
}